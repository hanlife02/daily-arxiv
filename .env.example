# 代理配置（国内访问 arXiv 可能需要）
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890

APP_URL=http://localhost:3000
DATABASE_URL=postgres://daily_arxiv:daily_arxiv@localhost:5432/daily_arxiv
REDIS_URL=redis://localhost:6379

BETTER_AUTH_SECRET=replace-with-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3000

FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Daily arXiv <noreply@example.com>

BACKUP_RETENTION_DAYS=7
