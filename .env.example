# 代理配置（国内访问 arXiv 可能需要）
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890

APP_URL=http://localhost:3211
APP_PORT=3211
# DATA_DIR=./data
DATABASE_URL=postgres://daily_arxiv:daily_arxiv@localhost:5433/daily_arxiv
REDIS_URL=redis://localhost:6379

BETTER_AUTH_SECRET=replace-with-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3211

FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Daily arXiv <noreply@example.com>

BACKUP_RETENTION_DAYS=7

# Health alerts
# HEALTH_ALERT_THROTTLE_MS=21600000
# HEALTH_ALERT_WEBHOOK_URL=
# QUEUE_HEALTH_LOG_INTERVAL_MS=1800000

# LLM cost estimates. Fill with your provider's current USD pricing per 1M tokens.
# LLM_COST_CHARS_PER_TOKEN=4
# LLM_COST_RATES_JSON={"gpt-example":{"promptUsdPerMillionTokens":0.1,"completionUsdPerMillionTokens":0.4}}

# Worker scheduler
# WORKER_SCHEDULER_DISABLED=false
# WORKER_SCHEDULER_INTERVAL_MS=300000
# ARXIV_CRAWL_INTERVAL_MS=21600000
